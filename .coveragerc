[run]
branch = True
source = .
omit =
    */tests/*
    */test_*
    */venv/*
    */virtualenv/*
    */site-packages/*
    */dist/*
    */build/*
    */.tox/*
    */__pycache__/*
    */migrations/*
    setup.py
    main.py
    */config/*
    medical_assistant.spec
    create_shortcut.vbs
    suppress_console.py
    runtime_hook_*.py
    hook-soundcard.py
    download_ffmpeg.py
    # UI files requiring display server (Tkinter/ttkbootstrap)
    src/ui/dialogs/*
    src/ui/chat_ui.py
    src/ui/workflow_ui.py
    src/ui/menu_manager.py
    src/ui/theme_manager.py
    src/ui/visual_components.py
    src/ui/components/notebook_tabs.py
    src/ui/components/notebook_analysis_mixin.py
    src/ui/components/notebook_rag_mixin.py
    src/ui/components/record_tab.py
    src/ui/components/shared_panel_manager.py
    src/ui/components/sidebar_sections_mixin.py
    src/ui/components/analysis_panel_formatter.py
    src/core/app.py
    src/core/app_initializer.py
    src/core/app_settings_mixin.py
    src/core/controllers/window_controller.py

[report]
# Regexes for lines to exclude from consideration
exclude_lines =
    # Have to re-enable the standard pragma
    pragma: no cover

    # Don't complain about missing debug-only code:
    def __repr__
    if self\.debug

    # Don't complain if tests don't hit defensive assertion code:
    raise AssertionError
    raise NotImplementedError

    # Don't complain if non-runnable code isn't run:
    if 0:
    if __name__ == .__main__.:
    
    # Don't complain about abstract methods
    @(abc\.)?abstractmethod
    
    # Type checking blocks
    if TYPE_CHECKING:
    if typing.TYPE_CHECKING:

ignore_errors = True
precision = 2
show_missing = True

[html]
directory = htmlcov

[xml]
output = coverage.xml

[paths]
source =
    .
    */site-packages/